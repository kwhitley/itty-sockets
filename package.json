{
  "name": "itty-sockets",
  "version": "0.5.4",
  "description": "WebSockets : simplified and minified.",
  "type": "module",
  "exports": {
    "./connect": {
      "import": "./dist/connect.mjs",
      "types": "./dist/connect.d.ts",
      "require": "./dist/connect.cjs"
    },
    "./ws": {
      "import": "./dist/ws.mjs",
      "types": "./dist/ws.d.ts",
      "require": "./dist/ws.cjs"
    }
  },
  "scripts": {
    "dev": "bun test --watch --coverage",
    "test": "bun test --coverage",
    "lint": "itty lint",
    "build": "itty lint && itty build --snippet=connect --hybrid",
    "release": "itty release --prepare --tag --push",
    "release:next": "itty release --prepare --tag --push --type=next"
  },
  "keywords": [
    "websockets",
    "realtime",
    "client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwhitley/itty-sockets.git"
  },
  "author": "Kevin R. Whitley <krwhitley@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kwhitley/itty-sockets/issues"
  },
  "devDependencies": {
    "@types/bun": "^1.2.3",
    "itty-packager": "^1.6.10"
  }
}
