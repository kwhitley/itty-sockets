{
  "name": "itty-sockets",
  "version": "0.5.2",
  "description": "WebSockets : simplified and minified.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/connect.mjs",
      "types": "./dist/connect.d.ts",
      "require": "./dist/connect.cjs"
    }
  },
  "scripts": {
    "dev": "bun test --watch",
    "lint": "itty lint",
    "verify": "echo 'verifying module...' && bun run build && bun test",
    "prerelease": "bun run verify",
    "prerelease:next": "bun run verify",
    "packager": "itty-packager",
    "prebuild": "itty lint",
    "build": "itty build --snippet=connect --hybrid",
    "dry-release": "itty publish --patch --tag --dry-run",
    "release": "release --tag --push --patch --src=dist",
    "release:next": "release --tag --push --type=next --src=dist"
  },
  "keywords": [
    "websockets",
    "realtime",
    "client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwhitley/itty-sockets.git"
  },
  "author": "Kevin R. Whitley <krwhitley@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kwhitley/itty-sockets/issues"
  },
  "devDependencies": {
    "@types/bun": "^1.2.3",
    "itty-packager": "itty-packager"
  }
}
